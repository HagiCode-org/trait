{
  "name": "trait",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run sync:agents && tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "sync:agents": "node ./scripts/sync-agents.mjs",
    "sync:agents:update-source": "git submodule update --init --remote",
